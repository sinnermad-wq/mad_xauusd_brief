# ---- Twelve Data (gold price + technical indicators) ----
TWELVE_DATA_API_KEY=your_twelve_data_key_here

# ---- NewsAPI (a.k.a. Event Registry — newsapi.ai) ----
# Default: newsapi.ai (Event Registry). Endpoint used is
# https://eventregistry.org/api/v1/article/getArticles. Key 採 UUID v4 格式。
NEWSAPI_KEY=your_newsapi_uuid_v4_key_here

# ---- Telegram Bot API (independent delivery, optional) ----
# Get these from @BotFather (token) and your chat/group (chat id).
# Leaving these empty disables direct Telegram delivery — local MD report still works.
# To get chat_id: DM your bot then visit
#   https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ---- Schedule ----
# Cron-style time. Hermes cron schedules resolve in Asia/Hong_Kong by default.
REPORT_HOUR=8
REPORT_MINUTE=0
TIMEZONE=Asia/Hong_Kong

# ---- Symbols ----
# Default: XAU/USD spot gold, priced in US dollars per troy ounce.
SYMBOL=XAU/USD

# ---- LLM 摘要 (可選 — v3+ 升級) ----
# 預設關閉 (ENABLE_LLM_SUMMARY=0). 設為 1 用 LLM 復個新聞做繁中摘要.
# Provider 預設 deepseek, 用 OpenAI-compatible SDK.
# API key 申請: https://platform.deepseek.com
ENABLE_LLM_SUMMARY=0
LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-chat
LLM_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_API_KEY=
